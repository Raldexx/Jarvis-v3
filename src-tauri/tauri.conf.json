{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JARVIS",
  "version": "3.1.0",
  "identifier": "com.raldexx.jarvis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JARVIS",
        "label": "main",
        "width": 420,
        "height": 920,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": true,
        "minWidth": 380,
        "minHeight": 600
      },
      {
        "title": "JARVIS \u2014 Spotify Stats",
        "label": "stats",
        "url": "stats.html",
        "width": 700,
        "height": 780,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "shadow": true,
        "minimizable": true,
        "closable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}